                                    "disabled": true
                                },
                                {
                                    "key": "limit",
                                    "value": "50",
                                    "description": "Max number of events (default: 50)",
                                    "disabled": true
                                }
                            ]
                        },
                        "description": "Get attendance event history from D1.\n\nReturns CHECK_IN, CHECK_OUT, and ATTENDANCE_DURATION events.\nAll timestamps are UTC ISO 8601."
                    },
                    "response": [
                        {
                            "name": "200 OK",
                            "status": "OK",
                            "code": 200,
                            "header": [
                                {
                                    "key": "Content-Type",
                                    "value": "application/json"
                                }
                            ],
                            "body": "{\n  \"count\": 3,\n  \"events\": [\n    {\n      \"id\": \"duration:dev-01:2026-03-12T10:30:00.000Z\",\n      \"developer_id\": \"dev-01\",\n      \"event_type\": \"ATTENDANCE_DURATION\",\n      \"source\": \"attendance\",\n      \"event_timestamp\": \"2026-03-12T10:30:00.000Z\",\n      \"metadata\": \"{\\\"checkin_time\\\":\\\"2026-03-12T09:00:00.000Z\\\",\\\"checkout_time\\\":\\\"2026-03-12T10:30:00.000Z\\\",\\\"duration_minutes\\\":90,\\\"duration_blocks\\\":6,\\\"block_size_minutes\\\":15}\"\n    },\n    {\n      \"id\": \"checkout:dev-01:2026-03-12T10:30:00.000Z\",\n      \"developer_id\": \"dev-01\",\n      \"event_type\": \"CHECK_OUT\",\n      \"source\": \"attendance\",\n      \"event_timestamp\": \"2026-03-12T10:30:00.000Z\"\n    },\n    {\n      \"id\": \"checkin:dev-01:2026-03-12T09:00:00.000Z\",\n      \"developer_id\": \"dev-01\",\n      \"event_type\": \"CHECK_IN\",\n      \"source\": \"attendance\",\n      \"event_timestamp\": \"2026-03-12T09:00:00.000Z\"\n    }\n  ]\n}"
                        }
                    ]
                }
            ]
        },
        {
            "name": "Webhooks",
            "item": [
                {
                    "name": "GitHub Webhook",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "X-GitHub-Event",
                                "value": "pull_request",
                                "description": "GitHub event type: pull_request | pull_request_review | issue_comment | pull_request_review_comment"
                            },
                            {
                                "key": "X-GitHub-Delivery",
                                "value": "{{$guid}}",
                                "description": "Unique delivery ID (auto-generated by GitHub)"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"action\": \"opened\",\n  \"pull_request\": {\n    \"number\": 42,\n    \"title\": \"feat: new feature\",\n    \"html_url\": \"https://github.com/Sellio-Squad/sellio_mobile/pull/42\",\n    \"created_at\": \"2026-03-12T10:00:00Z\",\n    \"user\": {\n      \"login\": \"dev-01\"\n    }\n  },\n  \"repository\": {\n    \"full_name\": \"Sellio-Squad/sellio_mobile\"\n  }\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/webhooks/github",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "webhooks",
                                "github"
                            ]
                        },
                        "description": "GitHub webhook endpoint for event-driven scoring.\n\nWhen GitHub sends a PR event, this endpoint:\n1. Invalidates cached PR metrics\n2. Ingests events into D1 with deterministic IDs (idempotent)\n3. Invalidates affected developer's score cache\n\nEvent types ingested:\n- pull_request (opened) → PR_CREATED (timestamp = pr.created_at)\n- pull_request (closed+merged) → PR_MERGED (timestamp = pr.merged_at)\n- pull_request_review → PR_REVIEW (timestamp = review.submitted_at)\n- issue_comment / review_comment → COMMENT (timestamp = comment.created_at)\n\nDuplicate webhooks are automatically de-duplicated via deterministic event IDs."
                    },
                    "response": [
                        {
                            "name": "200 OK (events ingested)",
                            "status": "OK",
                            "code": 200,
                            "header": [
                                {
                                    "key": "Content-Type",
                                    "value": "application/json"
                                }
                            ],
                            "body": "{\n  \"ok\": true,\n  \"event\": \"pull_request\",\n  \"repo\": \"Sellio-Squad/sellio_mobile\",\n  \"invalidated\": true,\n  \"eventsIngested\": 1,\n  \"duplicates\": 0\n}"
                        },
                        {
                            "name": "200 OK (duplicate - idempotent)",
                            "status": "OK",
                            "code": 200,
                            "header": [
                                {
                                    "key": "Content-Type",
                                    "value": "application/json"
                                }
                            ],
                            "body": "{\n  \"ok\": true,\n  \"event\": \"pull_request\",\n  \"repo\": \"Sellio-Squad/sellio_mobile\",\n  \"invalidated\": true,\n  \"eventsIngested\": 0,\n  \"duplicates\": 1\n}"
                        },
                        {
                            "name": "200 OK (ignored event type)",
                            "status": "OK",
                            "code": 200,
                            "header": [
                                {
                                    "key": "Content-Type",
                                    "value": "application/json"
                                }
                            ],
                            "body": "{\n  \"ignored\": true,\n  \"event\": \"push\"\n}"
                        }
                    ]
                }
            ]
